generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions          VendorSubscription[]    @relation("CreatedBy")
  uploadedForms          FormLibrary[]           @relation("UploadedBy")
  sharedTrackings        FormTracking[]          @relation("SharedBy")
  formNotifications      FormNotification[]      @relation("FormNotifs")
  itRequestNotifications ITRequestNotification[] @relation("ITReqNotifs")
}

model VendorSubscription {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  vendor             String
  department         String
  useFor             String
  servicesProviding  String
  nature             String
  subscriptionAmount Float
  subscriptionType   String
  date               DateTime
  renewalDate        DateTime?
  paidOneTime        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdById        String    @db.ObjectId
  createdBy          User      @relation("CreatedBy", fields: [createdById], references: [id])
  updatedByName      String    @default("")
  requestedBy        String    @default("")
  approvedBy         String    @default("")
  relation           String    @default("")
}

model FormLibrary {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  category         String
  filePath         String
  originalFileName String
  uploadedById     String         @db.ObjectId
  uploadedBy       User           @relation("UploadedBy", fields: [uploadedById], references: [id])
  createdAt        DateTime       @default(now())
  trackingRows     FormTracking[]
  shareToken       String?        @unique
  formFields       FormField[]    @relation("FormFields")
}

model FormField {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  formId    String      @db.ObjectId
  form      FormLibrary @relation("FormFields", fields: [formId], references: [id])
  label     String
  fieldType String
  options   String      @default("")
  required  Boolean     @default(false)
  order     Int         @default(0)
}

model FormTracking {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  formId            String             @db.ObjectId
  form              FormLibrary        @relation(fields: [formId], references: [id])
  sharedById        String             @db.ObjectId
  sharedBy          User               @relation("SharedBy", fields: [sharedById], references: [id])
  requesteeName     String
  requesteeEmail    String
  requesteeDept     String             @default("")
  state             String             @default("Shared")
  shareToken        String             @unique @default(cuid())
  submissionData    String             @default("")
  submittedFilePath String             @default("")
  submittedFileName String             @default("")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  notifications     FormNotification[]
}

model SoftwareRequest {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  requestedBy           String
  employeeId            String   @default("")
  department            String   @default("")
  designation           String   @default("")
  emailId               String
  requestDate           String   @default("")
  softwareName          String
  softwareVersion       String   @default("")
  vendorName            String   @default("")
  softwareCategory      String   @default("")
  licenseType           String   @default("")
  licensesRequired      String   @default("")
  installationOn        String   @default("")
  purposeOfInstallation String   @default("")
  businessImpact        String   @default("")
  policyPreparedBy      String   @default("")
  policyReviewedBy      String   @default("")
  policyApprovedBy      String   @default("")
  policyEffectiveDate   String   @default("")
  versionControl        String   @default("")
  techCompatibility     String   @default("")
  techAntivirusScan     String   @default("")
  techLicenseVerif      String   @default("")
  techVendorValidation  String   @default("")
  techAdminRights       String   @default("")
  techRemarks           String   @default("")
  secDlpCompliance      String   @default("")
  secRiskAssessment     String   @default("")
  secApprovalStatus     String   @default("")
  secRemarks            String   @default("")
  approvalMatrix        String   @default("")
  instCompletedBy       String   @default("")
  instDate              String   @default("")
  instSoftwareInstalled String   @default("")
  instLicenseUpdated    String   @default("")
  instAssetUpdated      String   @default("")
  instRemarks           String   @default("")
  ackEmployeeName       String   @default("")
  ackSignatureDate      String   @default("")
  state                 String   @default("Submitted")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  notifications         ITRequestNotification[]
}

model ITRequestNotification {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  userId            String          @db.ObjectId
  user              User            @relation("ITReqNotifs", fields: [userId], references: [id])
  message           String
  softwareRequestId String          @db.ObjectId
  softwareRequest   SoftwareRequest @relation(fields: [softwareRequestId], references: [id])
  read              Boolean         @default(false)
  createdAt         DateTime        @default(now())
}

model FormNotification {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  userId     String       @db.ObjectId
  user       User         @relation("FormNotifs", fields: [userId], references: [id])
  message    String
  trackingId String       @db.ObjectId
  tracking   FormTracking @relation(fields: [trackingId], references: [id])
  read       Boolean      @default(false)
  createdAt  DateTime     @default(now())
}
